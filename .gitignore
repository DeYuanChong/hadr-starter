# Transient report scratch — the build may write these; do not commit churn.
reports/
*.sitrep.html

# The published products (dashboard-map.html/.json) and the persisted run
# state (state.json) ARE committed — they are the reviewed artifacts the
# GitHub Pages deploy serves as-is. They are not ignored by anything above.

# Secrets stay out of the repo. `.env.example` is committed as documentation;
# a real `.env` is not.
.env
.env.*
!.env.example

# Dependencies and OS/editor debris.
__pycache__/
.venv/
node_modules/
.DS_Store
